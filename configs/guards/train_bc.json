{
  "guards": [
    {
      "name": "cli_flag_lint",
      "args": {
        "critical_flags": [
          "--optimizer",
          "--weight-decay",
          "--truncated-vp-margin-value-weight",
          "--lr-schedule",
          "--mask-hidden-info"
        ],
        "expected_values": {
          "--mask-hidden-info": true
        }
      }
    },
    {
      "name": "fd_limit",
      "args": {
        "minimum": 65536
      }
    }
  ]
}
